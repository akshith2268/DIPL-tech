DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  Options -MultiViews

  # Keep a single canonical host. Hostinger already upgrades HTTP to HTTPS.
  RewriteCond %{HTTP_HOST} ^www\.drithinfra\.in$ [NC]
  RewriteRule ^ https://drithinfra.in%{REQUEST_URI} [R=301,L,NE]

  # Public canonical URLs do not use trailing slashes, except for the homepage.
  RewriteCond %{REQUEST_URI} !^/$
  RewriteCond %{REQUEST_URI} /$
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+?)/$ /$1 [R=301,L,NE]

  # Pre-rendered files are implementation details and are never public URLs.
  RewriteCond %{THE_REQUEST} "\s/+_prerender(?:/|\s)" [NC]
  RewriteRule ^_prerender(?:/.*)?$ - [R=404,L]

  # Serve existing files and directories normally.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Serve statically rendered HTML for every public route listed in sitemap.xml.
  RewriteCond %{DOCUMENT_ROOT}/_prerender/$1.html -f
  RewriteRule ^([A-Za-z0-9_-]+(?:/[A-Za-z0-9_-]+)*)$ _prerender/$1.html [END]

  # Send application routes to React Router.
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Keep the private React admin route out of search indexes.
  SetEnvIf Request_URI "^/admin(/|$)" drith_admin_route
  Header always set X-Robots-Tag "noindex, nofollow, noarchive" env=drith_admin_route

  # Always check for a new HTML build after deployment.
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Vite filenames are content-hashed and safe to cache long-term.
  <FilesMatch "\.(?:js|css|woff2?|png|jpe?g|gif|svg|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>
