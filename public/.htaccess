DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  Options -MultiViews

  # Serve existing files and directories normally.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Send application routes to React Router.
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Always check for a new HTML build after deployment.
  <Files "index.html">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </Files>

  # Vite filenames are content-hashed and safe to cache long-term.
  <FilesMatch "\.(?:js|css|woff2?|png|jpe?g|gif|svg|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>
